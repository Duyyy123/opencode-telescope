[0.007, "o", "\u001b[?2026h\u001b[?25l\u001b[11;67H\u001b[38;2;202;211;245m\u001b[48;2;36;39;58mI need to address the question about the necessity of http-proxy. It seems that \u001b[0m\u001b[12;67H\u001b[38;2;202;211;245m\u001b[48;2;36;39;58mwithout explicitly including it in pnpm, the Kubernetes setup might miss it. In a \u001b[0m\u001b[13;67H\u001b[38;2;202;211;245m\u001b[48;2;36;39;58mproduction Docker environment, only traced dependencies are bundled, and if \u001b[0m\u001b[14;67H\u001b[38;2;202;211;245m\u001b[48;2;36;39;58mthere’\u001b[14;73Hs a custom script requiring something not traced, it could lead to issues. \u001b[0m\u001b[15;67H\u001b[38;2;202;211;245m\u001b[48;2;36;39;58mJust because a dependency is in the package doesn’\u001b[15;117Ht guarantee it’\u001b[15;132Hs present at \u001b[0m\u001b[15;150H\u001b[38;2;154;158;163m\u001b[48;2;37;37;39m█\u001b[0m\u001b[16;62H\u001b[38;2;255;255;255m\u001b[48;2;36;39;58m     \u001b[0m\u001b[16;67H\u001b[38;2;202;211;245m\u001b[48;2;36;39;58mruntime. If it’\u001b[16;82Hs missing from the pnpm lock, the build could fail, so I should \u001b[0m\u001b[16;146H\u001b[38;2;255;255;255m\u001b[48;2;36;39;58m   \u001b[0m\u001b[16;150H\u001b[38;2;154;158;163m\u001b[48;2;37;37;39m█\u001b[0m\u001b[17;62H\u001b[38;2;255;255;255m\u001b[48;2;36;39;58m     \u001b[0m\u001b[17;67H\u001b[38;2;202;211;245m\u001b[48;2;36;39;58mcheck the logs with \u001b[0m\u001b[17;87H\u001b[38;2;166;218;149m\u001b[48;2;36;39;58mkubectl logs deploy/... --previous\u001b[0m\u001b[17;121H\u001b[38;2;202;211;245m\u001b[48;2;36;39;58m.\u001b[0m\u001b[17;122H\u001b[38;2;255;255;255m\u001b[48;2;36;39;58m                           \u001b[0m\u001b[17;150H\u001b[38;2;154;158;163m\u001b[48;2;37;37;39m█\u001b[0m\u001b[18;62H\u001b[38;2;255;255;255m\u001b[48;2;36;39;58m                                                                                       \u001b[0m\u001b[18;150H\u001b[38;2;154;158;163m\u001b[48;2;37;37;39m█\u001b[0m\u001b[19;62H\u001b[38;2;255;255;255m\u001b[48;2;36;39;58m   \u001b[0m\u001b[19;65H\u001b[38;2;238;212;159m\u001b[48;2;36;39;58mmatch\u001b[0m\u001b[19;70H\u001b[38;2;147;154;183m\u001b[48;2;36;39;58m ·\u001b[19;72H assistant ·\u001b[19;84H Jun 22 12:02 PM\u001b[0m\u001b[19;100H\u001b[38;2;255;255;255m\u001b[48;2;36;39;58m                                                 \u001b[0m\u001b[19;150H\u001b[38;2;154;158;163m\u001b[48;2;37;37;39m█\u001b[0m\u001b[20;65H\u001b[38;2;147;154;183m\u001b[48;2;36;39;58m...ontend-proxy-server.js`. Replace `http-proxy` with native `http`/`https` proxy \u001b[0m\u001b[20;147H\u001b[38;2;238;212;159m\u001b[48;2;36;39;58m\u001b[1mhel\u001b[0m\u001b[20;150H\u001b[38;2;154;158;163m\u001b[48;2;37;37;39m█\u001b[0m\u001b[21;65H\u001b[38;2;202;211;245m\u001b[48;2;36;39;58mLikely yes: the pod can die because \u001b[0m\u001b[21;101H\u001b[38;2;166;218;149m\u001b[48;2;36;39;58mfrontend-proxy-server.js\u001b[0m\u001b[21;125H\u001b[38;2;202;211;245m\u001b[48;2;36;39;58m now does:\u001b[0m\u001b[24;65H\u001b[38;2;255;255;255m\u001b[48;2;36;39;58m                                                                                     \u001b[0m\u001b[25;65H\u001b[38;2;202;211;245m\u001b[48;2;36;39;58mBefore, it used only Node built-ins:\u001b[0m\u001b[26;65H\u001b[38;2;255;255;255m\u001b[48;2;36;39;58m                                         \u001b[0m\u001b[30;150H\u001b[38;2;255;255;255m\u001b[48;2;37;37;39m \u001b[0m\u001b[31;65H\u001b[38;2;202;211;245m\u001b[48;2;36;39;58mThe important difference is the Docker runtime uses Next standalone output:\u001b[0m\u001b[31;150H\u001b[38;2;255;255;255m\u001b[48;2;37;37;39m \u001b[0m\u001b[32;150H\u001b[38;2;255;255;255m\u001b[48;2;37;37;39m \u001b[0m\u001b[33;150H\u001b[38;2;255;255;255m\u001b[48;2;37;37;39m \u001b[0m\u001b[34;150H\u001b[38;2;255;255;255m\u001b[48;2;37;37;39m \u001b[0m\u001b[35;150H\u001b[38;2;255;255;255m\u001b[48;2;37;37;39m \u001b[0m\u001b[0m\u001b[?2026l"]
